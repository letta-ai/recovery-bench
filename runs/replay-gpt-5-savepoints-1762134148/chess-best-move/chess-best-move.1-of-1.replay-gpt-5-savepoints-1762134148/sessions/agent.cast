[204.51012, "o", "\u001b[?25l\u001b[0m\u001b[7m\u001b[38;5;223m \u001b[0m\u001b[38;5;1;48;5;223m         \u001b[48;5;137m          \u001b[48;5;223m          \u001b[48;5;137m          \u001b[48;5;223m          \u001b[48;5;137m          \u001b[48;5;223m          \u001b[48;5;137m          \u001b[0m\r\n\u001b[7m\u001b[38;5;223m \u001b[0m\u001b[38;5;1;48;5;223m \u001b[38;5;238;48;5;187mвХґ\u001b[38;5;233;48;5;180mвЦЦ\u001b[38;5;238;48;5;187mвЦД\u001b[38;5;241mвЦД\u001b[38;5;238mвЦЦ\u001b[48;5;223m   \u001b[48;5;137m          \u001b[48;5;223m    \u001b[38;5;234;48;5;187mвЦД\u001b[38;5;101;48;5;223mвЦП    \u001b[48;5;137m  \u001b[38;5;95mвЦБ\u001b[38;5;238mвЦГ\u001b[38;5;234mвЦЧ\u001b[38;5;235mвЦЧ    \u001b[48;5;223m          \u001b[48;5;137m  \u001b[38;5;236mвХґ\u001b[38;5;232;48;5;95mвЦЦ\u001b[38;5;236;48;5;137mвЦД\u001b[38;5;237mвЦД\u001b[38;5;236mвЦЦ   \u001b[48;5;223m          \u001b[48;5;137m          \u001b[0m\r\n\u001b[7m\u001b[38;5;223m \u001b[0m\u001b[38;5;180;48;5;223mвХї \u001b[38;5;187;48;5;232mвЦН\u001b[38;5;16;48;5;237mвЦЗ\u001b[38;5;232;48;5;138mвЦЙ\u001b[48;5;223m    \u001b[48;5;137m          \u001b[48;5;223m   \u001b[38;5;187;48;5;240mвЦЛ\u001b[38;5;144;48;5;235mвФЈ\u001b[38;5;238;48;5;187mвЦЛ\u001b[48;5;223m    \u001b[48;5;137m  \u001b[38;5;235mвЦЭ\u001b[38;5;137;48;5;235mвЦШ\u001b[48;5;236mвЦШ\u001b[38;5;233;48;5;240mвФГ\u001b[38;5;236;48;5;95mвФЫ\u001b[48;5;137m   \u001b[48;5;223m          \u001b[48;5;137m   \u001b[38;5;137;48;5;16mвЦН\u001b[38;5;16;48;5;235mвЦЗ\u001b[48;5;95mвЦЙ\u001b[48;5;137m    \u001b[48;5;223m          \u001b[48;5;137m          \u001b[0m\r\n\u001b[7m\u001b[38;5;223m \u001b[0m\u001b[38;5;223;48;5;181mвЦЗ\u001b[38;5;138;48;5;187mвЦБ\u001b[38;5;16;48;5;101mвЦЭ\u001b[38;5;138;48;5;16mвЦД\u001b[48;5;232mвЦД\u001b[38;5;241;48;5;187mвЦЦ\u001b[48;5;223m   \u001b[48;5;137m          \u001b[48;5;223m   \u001b[38;5;232;48;5;144mвЦЧ\u001b[48;5;16m \u001b[38;5;223;48;5;234mвЦЭ\u001b[48;5;187mвФИ\u001b[48;5;223m   \u001b[48;5;137m   \u001b[38;5;