[37.64567, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_serial_executable_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that the serial executable was compiled successfully.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m serial_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mSerial executable \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mserial_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Serial executable /app/serial does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/serial').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:14: AssertionError\r\n"]
