[37.660361, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_serial_output_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that serial version produced output file serial.out.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_out = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[37.66568, "o", ">       \u001b[94massert\u001b[39;49;00m serial_out.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mSerial output file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mserial_out\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Serial output file /app/serial.out does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/serial.out').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:39: AssertionError\r\n\u001b[31m\u001b[1m_________________________________________________________________ test_parallel_output_exists __________________________________________________________________\u001b[0m\r\n\r\n"]
[37.694675, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_parallel_output_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that parallel version produced output files starting with pgen.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Output files should end with .out (e.g., pgen_0.out, pgen_1.out).\u001b[39;49;00m\r\n"]
[37.695844, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for individual pgen_*.out files\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        pgen_files = \u001b[96mlist\u001b[39;49;00m(Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).glob(\u001b[33m\"\u001b[39;49;00m\u001b[33mpgen*.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(pgen_files) > \u001b[94m0\u001b[39;49;00m, \\\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mNo parallel output files found matching pattern pgen*.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: No parallel output files found matching pattern pgen*.out\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 0 > 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 0 = len([])\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:53: AssertionError\r\n\u001b[31m\u001b[1m__________________________________________________________________ test_outputs_are_identical __________________________________________________________________\u001b[0m\r\n"]
[37.697326, "o", "\r\n"]
[37.709957, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_outputs_are_identical\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that serial and parallel versions produce identical contigs when sorted.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_out = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Collect all contigs from serial output\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_contigs = \u001b[96mset\u001b[39;49;00m()\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m serial_out.exists():\u001b[90m\u001b[39;49;00m\r\n            content = serial_out.read_text()\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m content.strip().split(\u001b[33m'\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m line.strip():\u001b[90m\u001b[39;49;00m\r\n                    serial_contigs.add(line.strip())\u001b[90m\u001b[39;49;00m\r\n"]
[37.711099, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Collect all contigs from parallel outputs\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        parallel_contigs = \u001b[96mset\u001b[39;49;00m()\u001b[90m\u001b[39;49;00m\r\n        pgen_files = \u001b[96mlist\u001b[39;49;00m(Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).glob(\u001b[33m\"\u001b[39;49;00m\u001b[33mpgen*.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m pgen_file \u001b[95min\u001b[39;49;00m pgen_files:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m pgen_file.exists():\u001b[90m\u001b[39;49;00m\r\n                content = pgen_file.read_text()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m content.strip().split(\u001b[33m'\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m line.strip():\u001b[90m\u001b[39;49;00m\r\n                        parallel_contigs.add(line.strip())\u001b[90m\u001b[39;49;00m\r\n"]
[37.712685, "o", "    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(serial_contigs) > \u001b[94m0\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mNo contigs found in serial output\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: No contigs found in serial output\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 0 > 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 0 = len(set())\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:178: AssertionError\r\n============================================================================ PASSES ============================================================================\r\n"]
